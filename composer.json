{
    "name": "php-noobs/php-retype",
    "description": "Semantic PHP type refactoring service built on member-graph and php-source-registry.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PhpNoobs\\PhpRetype\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpNoobs\\PhpRetype\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/php-noobs/member-graph"
        },
        {
            "type": "vcs",
            "url": "https://github.com/php-noobs/php-source-registry"
        }
    ],
    "require": {
        "php": ">=8.4",
        "php-noobs/member-graph": "dev-main",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "qa": [
            "@cs",
            "@analyse",
            "@test"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
